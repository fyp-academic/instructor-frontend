INSERT INTO interventions (id, learner_id, course_id, facilitator_id, week_number, tier, trigger_score, profile_type, channel, template_id, message_body, sent_at, score_at_t7, score_at_t14, outcome, cooldown_expires_at, notes) VALUES

('iv_p6_w5','p6','course1',NULL,5, 1,42.6,'T','lms_message','T_T1_nudge',
  'Hi Frank — we noticed this week has been a bit quieter than usual in the course. Topic 5 is one of the more challenging sections, and we can see you''ve been working through the quiz multiple times — that persistence is great. It might be worth reviewing the structured example problems in the Week 5 resources before your next attempt. Your learning contract targets are still within reach. Let us know if there''s anything we can clarify.',
  '2026-02-17T08:00:00Z', 38.2,35.1,'partial_recovery','2026-02-24T08:00:00Z',
  'Auto-generated T1 T-profile nudge. Score showed slight improvement at T+7 and T+14. Partial recovery. No escalation required.'),

('iv_p4_w5','p4','course1',NULL,5, 1,42.6,'C','lms_message','C_T1_structured_nudge',
  'Hi David — we want to make sure you''re on track with your course goals. It looks like Week 5 has been a difficult one — the OOP content is genuinely complex. We''ve added a structured revision checklist to your dashboard that maps to the quiz outcomes. Your weekly schedule and milestone targets are also visible in your learning plan. If you''d like to speak with your instructor, office hours are available Thursday 2–4pm. Let us know how we can help you stay on track.',
  '2026-02-17T08:05:00Z', 48.1,52.8,'no_change','2026-02-24T08:05:00Z',
  'Auto T1 C-profile nudge. Score continued to rise at T+7 and T+14. No recovery. Escalated to T2 at W7.'),

('iv_p4_w7','p4','course1','user1',7, 2,64.1,'C','lms_message','C_T2_pedagogical',
  'Hi David — I wanted to check in personally. I can see Topics 5 and 6 have been really tough, and you''ve been revisiting a lot of the core material. That tells me you''re trying — and that matters. I''d love to have a short conversation to understand what''s feeling unclear and to see if the way the content is structured is working for you. I''ve also extended your Week 6 assignment deadline by 5 days — that''s reflected in your dashboard now. Can we arrange a 15-minute call this week? Let me know what time works best.',
  '2026-03-02T10:30:00Z', NULL,NULL,NULL,NULL,
  'T2 facilitator outreach. C-profile tone: structured, concrete offer (deadline extension), direct meeting request. Awaiting learner response.'),

('iv_p8_w5','p8','course1',NULL,5, 2,64.1,'A','lms_message','A_T2_social_outreach',
  'Hi Henry — I''ve noticed it''s been quieter from you in the course this week, and I just wanted to check in. The group discussion for Topic 5 is still open — your perspective on the ethics case study would be really valuable to your peers. A few students have been asking questions in the forum that are right in your wheelhouse. If you''ve been finding things difficult or just haven''t had the headspace, that''s completely okay — just let me know and we can work something out together.',
  '2026-02-17T08:10:00Z', 68.2,72.1,'no_change','2026-02-24T08:10:00Z',
  'Auto T2 A-profile social nudge. No forum response, no peer engagement. Score worsened. Escalated to T3.'),

('iv_p8_w7','p8','course1','user1',7, 3,78.5,'A','video_call','A_T3_pastoral',
  'Hi Henry — I''m reaching out because I''m genuinely concerned and want to understand how you''re doing. This isn''t about grades or deadlines — I just want to have a real conversation. I''ve arranged a video call for this Thursday at 11am (calendar invite sent). If that doesn''t work, please message me and we''ll find another time. You''re not in trouble — I just want to make sure you''re okay and that you feel supported.',
  '2026-03-02T10:00:00Z', NULL,NULL,NULL,NULL,
  'TIER 3 pastoral escalation. A-profile: led with care, not performance. Video call scheduled. Student support services also notified.')
ON CONFLICT (id) DO NOTHING;

