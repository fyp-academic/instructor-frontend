-- =============================================================================
-- =============================================================================
--  UTILITY VIEWS
-- =============================================================================
-- =============================================================================

-- ─────────────────────────────────────────────────────────────────────────────
--  VIEW: v_current_risk_status
--  Returns the most recent risk score row per learner per course.
-- ─────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE VIEW v_current_risk_status AS
SELECT DISTINCT ON (rs.learner_id, rs.course_id)
    rs.learner_id,
    u.name              AS learner_name,
    rs.course_id,
    c.name              AS course_name,
    rs.week_number      AS latest_week,
    rs.profile_type,
    lp.primary_profile,
    lp.secondary_profile,
    lp.drift_flag       AS profile_drift_flag,
    rs.final_score,
    rs.previous_week_score,
    rs.score_delta,
    rs.tier,
    rs.anomaly_flag,
    rs.facilitator_notes_prompt,
    rs.computed_at
FROM risk_scores rs
JOIN users            u  ON u.id  = rs.learner_id
JOIN courses          c  ON c.id  = rs.course_id
LEFT JOIN learner_profiles lp ON lp.learner_id = rs.learner_id
                              AND lp.course_id  = rs.course_id
ORDER BY rs.learner_id, rs.course_id, rs.week_number DESC;

-- ─────────────────────────────────────────────────────────────────────────────
--  VIEW: v_at_risk_action_required
--  Returns all learners currently at Tier 1+ with pending intervention status.
-- ─────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE VIEW v_at_risk_action_required AS
SELECT
    crs.learner_name,
    crs.course_name,
    crs.profile_type,
    crs.final_score,
    crs.score_delta,
    crs.tier,
    CASE crs.tier
        WHEN 1 THEN 'AMBER  — Monitor / Auto-nudge'
        WHEN 2 THEN 'ORANGE — Facilitator outreach within 48hrs'
        WHEN 3 THEN 'RED    — Immediate pastoral escalation'
    END AS action_label,
    crs.anomaly_flag,
    crs.profile_drift_flag,
    crs.facilitator_notes_prompt,
    iv.id           AS latest_intervention_id,
    iv.tier         AS intervention_tier,
    iv.channel      AS intervention_channel,
    iv.sent_at      AS intervention_sent_at,
    iv.outcome      AS intervention_outcome
FROM v_current_risk_status crs
LEFT JOIN LATERAL (
    SELECT * FROM interventions
    WHERE learner_id = crs.learner_id
      AND course_id  = crs.course_id
    ORDER BY created_at DESC
    LIMIT 1
) iv ON TRUE
WHERE crs.tier >= 1
ORDER BY crs.tier DESC, crs.final_score DESC;

-- ─────────────────────────────────────────────────────────────────────────────
--  VIEW: v_gradebook
--  Pivots grade data for the Gradebook UI component.
-- ─────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE VIEW v_gradebook AS
SELECT
    sg.student_id,
    sg.student_name,
    gi.course_id,
    gi.id           AS grade_item_id,
    gi.activity_name,
    gi.activity_type,
    gi.grade_max,
    sg.grade,
    sg.percentage,
    sg.status,
    sg.feedback,
    sg.submitted_date
FROM student_grades sg
JOIN grade_items     gi ON gi.id = sg.grade_item_id
ORDER BY sg.student_name, gi.id;

-- ─────────────────────────────────────────────────────────────────────────────
--  VIEW: v_course_summary
--  Dashboard / admin overview of all courses with key metrics.
-- ─────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE VIEW v_course_summary AS
SELECT
    c.id,
    c.name,
    c.short_name,
    c.status,
    c.visibility,
    c.format,
    c.start_date,
    c.end_date,
    c.instructor_name,
    c.enrolled_students,
    c.category_name,
    COUNT(DISTINCT s.id)    AS section_count,
    COUNT(DISTINCT a.id)    AS activity_count
FROM courses   c
LEFT JOIN sections  s ON s.course_id = c.id
LEFT JOIN activities a ON a.course_id = c.id
GROUP BY c.id, c.name, c.short_name, c.status, c.visibility,
         c.format, c.start_date, c.end_date, c.instructor_name,
         c.enrolled_students, c.category_name
ORDER BY c.status, c.name;

-- ─────────────────────────────────────────────────────────────────────────────
--  VIEW: v_learner_pipeline_summary
--  Full pipeline view per learner per week: L0 + L1 + L2 + L3 + RE + IE.
-- ─────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE VIEW v_learner_pipeline_summary AS
SELECT
    rs.learner_id,
    u.name                                      AS learner_name,
    rs.course_id,
    rs.week_number,
    -- L0
    lp.primary_profile,
    lp.secondary_profile,
    lp.is_mixed_profile,
    lp.drift_flag                               AS l0_drift_flag,
    -- L1
    bs.login_frequency,
    bs.time_on_task_hours,
    bs.content_completion_rate,
    bs.submission_timing,
    bs.forum_post_count,
    bs.navigation_pattern,
    -- L2
    cs.content_revisit_rate,
    cs.revisit_flag,
    cs.quiz_learning_delta,
    cs.optional_resource_access_rate,
    cs.feedback_uptake_lag_hours,
    -- L3
    es.pulse_composite,
    es.mood_drift_score,
    es.mood_drift_flag,
    es.voluntary_engagement_rate,
    es.voluntary_engagement_delta,
    es.help_seeking_rate,
    -- RE
    rs.l1_contribution,
    rs.l2_contribution,
    rs.l3_contribution,
    rs.final_score,
    rs.previous_week_score,
    rs.score_delta,
    rs.tier,
    rs.anomaly_flag,
    rs.facilitator_notes_prompt,
    -- IE
    iv.id                                       AS intervention_id,
    iv.tier                                     AS intervention_tier,
    iv.channel                                  AS intervention_channel,
    iv.template_id,
    iv.sent_at                                  AS intervention_sent_at,
    iv.outcome                                  AS intervention_outcome
FROM risk_scores          rs
JOIN users                u   ON u.id   = rs.learner_id
LEFT JOIN learner_profiles lp  ON lp.learner_id = rs.learner_id AND lp.course_id  = rs.course_id
LEFT JOIN behavioral_signals bs ON bs.learner_id = rs.learner_id AND bs.course_id = rs.course_id AND bs.week_number = rs.week_number
LEFT JOIN cognitive_signals  cs ON cs.learner_id = rs.learner_id AND cs.course_id = rs.course_id AND cs.week_number = rs.week_number
LEFT JOIN emotional_signals  es ON es.learner_id = rs.learner_id AND es.course_id = rs.course_id AND es.week_number = rs.week_number
LEFT JOIN LATERAL (
    SELECT * FROM interventions
    WHERE learner_id = rs.learner_id
      AND course_id  = rs.course_id
      AND week_number = rs.week_number
    ORDER BY created_at DESC LIMIT 1
) iv ON TRUE
ORDER BY rs.learner_id, rs.course_id, rs.week_number;

-- =============================================================================
-- END OF SCHEMA
-- =============================================================================
--
--  SUMMARY
--  ───────
--  Tables:   30
--  Views:     4  (v_current_risk_status, v_at_risk_action_required,
--                 v_gradebook, v_course_summary, v_learner_pipeline_summary)
--  Indexes:  50+
--
--  CORE LMS (Tables 1–22):
--    users, categories, courses, sections, activities, enrollments,
--    grade_items, student_grades, notifications, conversations, messages,
--    quiz_questions, quiz_answers, ai_performance_snapshots, ai_skill_metrics,
--    ai_at_risk_students, ai_recommendations, ai_content_recommendations,
--    ai_generated_questions, user_preferences, activity_performance,
--    dashboard_engagement
--
--  LEARNER ANALYTICS PIPELINE (Tables 23–30):
--    learner_profiles (L0)       — declared HATC profile + LMS flags
--    behavioral_signals (L1)     — weekly LMS log extraction
--    cognitive_signals (L2)      — xAPI/LRS computed processing metrics
--    emotional_signals (L3)      — pulse check-ins + mood drift computation
--    risk_scores (RE)            — weighted aggregation → tier 0–3
--    interventions (IE)          — tier-triggered templated outreach
--    feedback_evaluations (FL)   — T+7 / T+14 outcome scoring
--    profile_drift_logs (FL)     — behavioural divergence from L0 profile
--
-- =============================================================================
