-- =============================================================================
--  EduAI LMS — Complete Database Schema
--  system.db  |  PostgreSQL / Supabase dialect
--  Generated from: json.md
--  Tables: 30  |  Engine: L0 → L1 → L2 → L3 → RE → IE → FL Pipeline
-- =============================================================================
--
--  EXECUTION ORDER (respects foreign key dependencies):
--    1.  users
--    2.  categories
--    3.  courses
--    4.  sections
--    5.  activities
--    6.  enrollments
--    7.  grade_items
--    8.  student_grades
--    9.  notifications
--    10. conversations
--    11. messages
--    12. quiz_questions
--    13. quiz_answers
--    14. ai_performance_snapshots
--    15. ai_skill_metrics
--    16. ai_at_risk_students
--    17. ai_recommendations
--    18. ai_content_recommendations
--    19. ai_generated_questions
--    20. user_preferences
--    21. activity_performance
--    22. dashboard_engagement
--    23. learner_profiles          (L0)
--    24. behavioral_signals        (L1)
--    25. cognitive_signals         (L2)
--    26. emotional_signals         (L3)
--    27. risk_scores               (RE)
--    28. interventions             (IE)
--    29. feedback_evaluations      (FL)
--    30. profile_drift_logs        (FL)
--
-- =============================================================================

-- ─────────────────────────────────────────────────────────────────────────────
-- EXTENSIONS
-- ─────────────────────────────────────────────────────────────────────────────
CREATE EXTENSION IF NOT EXISTS "pgcrypto";   -- for gen_random_uuid()
CREATE EXTENSION IF NOT EXISTS "pg_trgm";    -- for full-text/search indexes

-- =============================================================================
--  TABLE 1: users
--  All platform users: admins, instructors, and students.
-- =============================================================================
CREATE TABLE IF NOT EXISTS users (
    id                  TEXT            PRIMARY KEY,
    name                TEXT            NOT NULL,
    email               TEXT            NOT NULL UNIQUE,
    role                TEXT            NOT NULL
                                        CHECK (role IN ('admin', 'instructor', 'student')),
    initials            TEXT,                          -- derived display field (e.g. "SJ")
    department          TEXT,
    institution         TEXT,
    country             TEXT,
    timezone            TEXT,                          -- IANA tz string e.g. "America/New_York"
    language            TEXT            DEFAULT 'English',
    bio                 TEXT,
    join_date           DATE,
    last_access         TEXT,                          -- human-readable string or ISO timestamp
    enrolled_courses    INTEGER         DEFAULT 0,
    created_at          TIMESTAMPTZ     DEFAULT NOW(),
    updated_at          TIMESTAMPTZ     DEFAULT NOW()
);

-- Indexes
CREATE INDEX IF NOT EXISTS idx_users_role  ON users (role);
CREATE INDEX IF NOT EXISTS idx_users_email ON users USING gin (email gin_trgm_ops);

-- =============================================================================
--  TABLE 2: categories
--  Hierarchical course categories (self-referential parent).
-- =============================================================================
CREATE TABLE IF NOT EXISTS categories (
    id              TEXT            PRIMARY KEY,
    name            TEXT            NOT NULL,
    description     TEXT,
    parent_id       TEXT            REFERENCES categories (id) ON DELETE SET NULL,
    id_number       TEXT            UNIQUE,            -- institutional identifier e.g. "CS-WEB"
    course_count    INTEGER         DEFAULT 0,
    child_count     INTEGER         DEFAULT 0,
    created_at      TIMESTAMPTZ     DEFAULT NOW(),
    updated_at      TIMESTAMPTZ     DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_categories_parent ON categories (parent_id);

-- =============================================================================
--  TABLE 3: courses
--  The central entity. Belongs to a category, owned by an instructor.
-- =============================================================================
CREATE TABLE IF NOT EXISTS courses (
    id                  TEXT        PRIMARY KEY,
    name                TEXT        NOT NULL,
    short_name          TEXT        NOT NULL UNIQUE,   -- e.g. "PYTH101"
    description         TEXT,
    category_id         TEXT        REFERENCES categories (id) ON DELETE SET NULL,
    category_name       TEXT,                          -- denormalised display cache
    instructor_id       TEXT        REFERENCES users (id) ON DELETE SET NULL,
    instructor_name     TEXT,                          -- denormalised display cache
    enrolled_students   INTEGER     DEFAULT 0,
    status              TEXT        NOT NULL DEFAULT 'draft'
                                    CHECK (status IN ('active', 'draft', 'archived')),
    visibility          TEXT        NOT NULL DEFAULT 'hidden'
                                    CHECK (visibility IN ('shown', 'hidden')),
    format              TEXT        NOT NULL DEFAULT 'topics'
                                    CHECK (format IN ('topics', 'weekly', 'social')),
    start_date          DATE,
    end_date            DATE,
    language            TEXT        DEFAULT 'English',
    tags                TEXT[]      DEFAULT '{}',      -- PostgreSQL text array
    max_students        INTEGER,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_courses_category   ON courses (category_id);
CREATE INDEX IF NOT EXISTS idx_courses_instructor ON courses (instructor_id);
CREATE INDEX IF NOT EXISTS idx_courses_status     ON courses (status);

-- =============================================================================
--  TABLE 4: sections
--  Course content is grouped into sections (weeks / topics / units).
-- =============================================================================
CREATE TABLE IF NOT EXISTS sections (
    id          TEXT        PRIMARY KEY,
    course_id   TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    title       TEXT        NOT NULL,
    summary     TEXT,
    sort_order  INTEGER     NOT NULL DEFAULT 0,
    visible     BOOLEAN     NOT NULL DEFAULT TRUE,
    collapsed   BOOLEAN     NOT NULL DEFAULT FALSE,
    created_at  TIMESTAMPTZ DEFAULT NOW(),
    updated_at  TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_sections_course ON sections (course_id, sort_order);

-- =============================================================================
--  TABLE 5: activities
--  Individual learning items inside a section.
--  10 supported types: quiz, assignment, forum, url, file,
--                      h5p, scorm, workshop, label, page
-- =============================================================================
CREATE TABLE IF NOT EXISTS activities (
    id                  TEXT        PRIMARY KEY,
    section_id          TEXT        NOT NULL REFERENCES sections (id) ON DELETE CASCADE,
    course_id           TEXT        NOT NULL REFERENCES courses  (id) ON DELETE CASCADE,
    type                TEXT        NOT NULL
                                    CHECK (type IN (
                                        'quiz', 'assignment', 'forum', 'url', 'file',
                                        'h5p', 'scorm', 'workshop', 'label', 'page'
                                    )),
    name                TEXT        NOT NULL,
    description         TEXT,
    due_date            DATE,
    visible             BOOLEAN     NOT NULL DEFAULT TRUE,
    completion_status   TEXT        DEFAULT 'none'
                                    CHECK (completion_status IN ('completed', 'incomplete', 'none')),
    grade_max           NUMERIC(7,2),
    sort_order          INTEGER     NOT NULL DEFAULT 0,
    settings            JSONB       DEFAULT '{}',      -- flexible per-type config
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_activities_section ON activities (section_id, sort_order);
CREATE INDEX IF NOT EXISTS idx_activities_course  ON activities (course_id);
CREATE INDEX IF NOT EXISTS idx_activities_type    ON activities (type);

-- =============================================================================
--  TABLE 6: enrollments  (previously "participants")
--  Junction between users and courses; holds role, progress, groups.
-- =============================================================================
CREATE TABLE IF NOT EXISTS enrollments (
    id              TEXT        PRIMARY KEY,
    user_id         TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    role            TEXT        NOT NULL DEFAULT 'student'
                                CHECK (role IN (
                                    'student', 'instructor', 'teaching_assistant', 'observer'
                                )),
    enrolled_date   DATE        NOT NULL DEFAULT CURRENT_DATE,
    last_access     TEXT,                              -- human-readable or ISO
    progress        NUMERIC(5,2) DEFAULT 0             -- 0–100 percentage
                                CHECK (progress >= 0 AND progress <= 100),
    groups          TEXT[]      DEFAULT '{}',
    created_at      TIMESTAMPTZ DEFAULT NOW(),
    updated_at      TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE (user_id, course_id)
);

CREATE INDEX IF NOT EXISTS idx_enrollments_user   ON enrollments (user_id);
CREATE INDEX IF NOT EXISTS idx_enrollments_course ON enrollments (course_id);
CREATE INDEX IF NOT EXISTS idx_enrollments_role   ON enrollments (role);

-- =============================================================================
--  TABLE 7: grade_items
--  Gradeable activity definitions for a course's gradebook.
-- =============================================================================
CREATE TABLE IF NOT EXISTS grade_items (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses    (id) ON DELETE CASCADE,
    activity_id     TEXT        REFERENCES activities (id) ON DELETE SET NULL,
    activity_name   TEXT        NOT NULL,
    activity_type   TEXT        NOT NULL
                                CHECK (activity_type IN (
                                    'quiz', 'assignment', 'forum', 'url', 'file',
                                    'h5p', 'scorm', 'workshop', 'label', 'page'
                                )),
    grade_max       NUMERIC(7,2) NOT NULL DEFAULT 100,
    created_at      TIMESTAMPTZ DEFAULT NOW(),
    updated_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_grade_items_course   ON grade_items (course_id);
CREATE INDEX IF NOT EXISTS idx_grade_items_activity ON grade_items (activity_id);

-- =============================================================================
--  TABLE 8: student_grades
--  Individual student submission/grade records per grade item.
-- =============================================================================
CREATE TABLE IF NOT EXISTS student_grades (
    id              TEXT            PRIMARY KEY,
    grade_item_id   TEXT            NOT NULL REFERENCES grade_items (id) ON DELETE CASCADE,
    student_id      TEXT            NOT NULL REFERENCES users      (id) ON DELETE CASCADE,
    student_name    TEXT            NOT NULL,          -- denormalised for quick display
    grade           NUMERIC(7,2),                      -- NULL = not submitted
    percentage      NUMERIC(5,2),                      -- NULL = not submitted
    feedback        TEXT,
    submitted_date  DATE,
    status          TEXT            NOT NULL DEFAULT 'not_submitted'
                                    CHECK (status IN (
                                        'graded', 'submitted', 'not_submitted', 'late'
                                    )),
    created_at      TIMESTAMPTZ     DEFAULT NOW(),
    updated_at      TIMESTAMPTZ     DEFAULT NOW(),
    UNIQUE (grade_item_id, student_id)
);

CREATE INDEX IF NOT EXISTS idx_student_grades_item    ON student_grades (grade_item_id);
CREATE INDEX IF NOT EXISTS idx_student_grades_student ON student_grades (student_id);
CREATE INDEX IF NOT EXISTS idx_student_grades_status  ON student_grades (status);

-- =============================================================================
--  TABLE 9: notifications
--  System and activity-driven notifications delivered to a user.
-- =============================================================================
CREATE TABLE IF NOT EXISTS notifications (
    id          TEXT        PRIMARY KEY,
    user_id     TEXT        NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    title       TEXT        NOT NULL,
    message     TEXT        NOT NULL,
    timestamp   TEXT        NOT NULL,                  -- human-readable relative string
    read        BOOLEAN     NOT NULL DEFAULT FALSE,
    type        TEXT        NOT NULL DEFAULT 'info'
                            CHECK (type IN ('info', 'warning', 'success', 'danger')),
    created_at  TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_notifications_user ON notifications (user_id, read);

-- =============================================================================
--  TABLE 10: conversations
--  One-to-one messaging threads between two users.
-- =============================================================================
CREATE TABLE IF NOT EXISTS conversations (
    id                      TEXT        PRIMARY KEY,
    owner_user_id           TEXT        NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    participant_user_id     TEXT        NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    participant_name        TEXT        NOT NULL,       -- denormalised display cache
    participant_role        TEXT        NOT NULL,       -- display label e.g. "Student"
    last_message            TEXT,
    last_message_time       TEXT,                      -- human-readable or ISO
    unread_count            INTEGER     NOT NULL DEFAULT 0,
    course_id               TEXT        REFERENCES courses (id) ON DELETE SET NULL,
    created_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_at              TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE (owner_user_id, participant_user_id)
);

CREATE INDEX IF NOT EXISTS idx_conversations_owner       ON conversations (owner_user_id);
CREATE INDEX IF NOT EXISTS idx_conversations_participant ON conversations (participant_user_id);

-- =============================================================================
--  TABLE 11: messages
--  Individual messages inside a conversation thread.
-- =============================================================================
CREATE TABLE IF NOT EXISTS messages (
    id              TEXT        PRIMARY KEY,
    conversation_id TEXT        NOT NULL REFERENCES conversations (id) ON DELETE CASCADE,
    sender_id       TEXT        NOT NULL REFERENCES users         (id) ON DELETE CASCADE,
    sender_name     TEXT        NOT NULL,              -- denormalised display cache
    content         TEXT        NOT NULL,
    timestamp       TEXT        NOT NULL,              -- human-readable or ISO
    read            BOOLEAN     NOT NULL DEFAULT FALSE,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_messages_conversation ON messages (conversation_id);
CREATE INDEX IF NOT EXISTS idx_messages_sender       ON messages (sender_id);

-- =============================================================================
--  TABLE 12: quiz_questions
--  Question bank entries linked to quiz activities.
--  8 question types: multiple_choice, true_false, matching, short_answer,
--                    numerical, essay, calculated, drag_drop
-- =============================================================================
CREATE TABLE IF NOT EXISTS quiz_questions (
    id                  TEXT        PRIMARY KEY,
    activity_id         TEXT        REFERENCES activities (id) ON DELETE SET NULL,
    course_id           TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    type                TEXT        NOT NULL
                                    CHECK (type IN (
                                        'multiple_choice', 'true_false', 'matching',
                                        'short_answer', 'numerical', 'essay',
                                        'calculated', 'drag_drop'
                                    )),
    question_text       TEXT        NOT NULL,
    category            TEXT,                          -- topic/chapter tag
    default_mark        NUMERIC(6,2) NOT NULL DEFAULT 1,
    shuffle_answers     BOOLEAN     DEFAULT FALSE,
    multiple_answers    BOOLEAN     DEFAULT FALSE,
    correct_answer      TEXT,                          -- for true_false / short_answer / numerical
    penalty             NUMERIC(4,3) DEFAULT 0,        -- fraction deducted per wrong attempt
    hints               TEXT[]      DEFAULT '{}',
    matching_pairs      JSONB       DEFAULT '[]',      -- [{question, answer}] for matching type
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_quiz_questions_activity ON quiz_questions (activity_id);
CREATE INDEX IF NOT EXISTS idx_quiz_questions_course   ON quiz_questions (course_id);
CREATE INDEX IF NOT EXISTS idx_quiz_questions_type     ON quiz_questions (type);

-- =============================================================================
--  TABLE 13: quiz_answers
--  Answer options for multiple-choice / matching questions.
--  grade_fraction: 1.0 = correct, 0 = wrong, negative = penalty
-- =============================================================================
CREATE TABLE IF NOT EXISTS quiz_answers (
    id              TEXT            PRIMARY KEY,
    question_id     TEXT            NOT NULL REFERENCES quiz_questions (id) ON DELETE CASCADE,
    text            TEXT            NOT NULL,
    grade_fraction  NUMERIC(5,4)    NOT NULL DEFAULT 0
                                    CHECK (grade_fraction >= -1 AND grade_fraction <= 1),
    feedback        TEXT,
    sort_order      INTEGER         NOT NULL DEFAULT 0,
    created_at      TIMESTAMPTZ     DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_quiz_answers_question ON quiz_answers (question_id);

-- =============================================================================
--  TABLE 14: ai_performance_snapshots
--  Weekly course-level KPI snapshots used to render the Weekly Trends chart
--  on AI Insights → Performance Analysis.
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_performance_snapshots (
    id                  TEXT        PRIMARY KEY,
    course_id           TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    week_label          TEXT        NOT NULL,          -- e.g. "W1", "W7"
    avg_grade           NUMERIC(5,2),                  -- 0–100
    completion_rate     NUMERIC(5,2),                  -- 0–100
    engagement_score    NUMERIC(5,2),                  -- 0–100
    recorded_at         DATE        NOT NULL,
    created_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_perf_course ON ai_performance_snapshots (course_id, recorded_at);

-- =============================================================================
--  TABLE 15: ai_skill_metrics
--  Radar chart data per course — one row per skill dimension per snapshot date.
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_skill_metrics (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    skill_label     TEXT        NOT NULL,              -- e.g. "Quiz Performance"
    score           NUMERIC(5,2) NOT NULL,             -- 0–100
    full_mark       NUMERIC(5,2) NOT NULL DEFAULT 100,
    recorded_at     DATE        NOT NULL,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_skill_course ON ai_skill_metrics (course_id, recorded_at);

-- =============================================================================
--  TABLE 16: ai_at_risk_students
--  GPT-generated at-risk student records (legacy/simplified risk view).
--  For full pipeline detail see risk_scores (RE) + behavioral/cognitive/emotional signals.
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_at_risk_students (
    id                  TEXT        PRIMARY KEY,
    course_id           TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    student_id          TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    student_name        TEXT        NOT NULL,
    progress            NUMERIC(5,2),
    last_access         TEXT,
    missed_activities   INTEGER     DEFAULT 0,
    grade               NUMERIC(5,2),
    risk_level          TEXT        NOT NULL DEFAULT 'medium'
                                    CHECK (risk_level IN ('high', 'medium', 'low')),
    ai_recommendation   TEXT,
    detected_at         DATE        NOT NULL DEFAULT CURRENT_DATE,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_risk_course    ON ai_at_risk_students (course_id);
CREATE INDEX IF NOT EXISTS idx_ai_risk_student   ON ai_at_risk_students (student_id);
CREATE INDEX IF NOT EXISTS idx_ai_risk_level     ON ai_at_risk_students (risk_level);

-- =============================================================================
--  TABLE 17: ai_recommendations
--  Pedagogical suggestions generated by GPT for the AI Suggestions tab.
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_recommendations (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    title           TEXT        NOT NULL,
    description     TEXT        NOT NULL,
    impact_level    TEXT        NOT NULL DEFAULT 'medium'
                                CHECK (impact_level IN ('high', 'medium', 'urgent', 'low')),
    icon_name       TEXT,                              -- Lucide icon identifier e.g. "Zap"
    color_scheme    TEXT,                              -- e.g. "purple", "amber", "blue", "red"
    generated_at    DATE        NOT NULL DEFAULT CURRENT_DATE,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_recommendations_course ON ai_recommendations (course_id);

-- =============================================================================
--  TABLE 18: ai_content_recommendations
--  External/internal resource links surfaced by GPT based on performance gaps.
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_content_recommendations (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    title           TEXT        NOT NULL,
    content_type    TEXT        NOT NULL
                                CHECK (content_type IN (
                                    'Video', 'Article', 'Interactive',
                                    'Quiz Bank', 'Document'
                                )),
    relevance_score NUMERIC(5,2) NOT NULL               -- 0–100
                                CHECK (relevance_score >= 0 AND relevance_score <= 100),
    source          TEXT,                              -- e.g. "YouTube", "Real Python", "Internal"
    url             TEXT,
    generated_at    DATE        NOT NULL DEFAULT CURRENT_DATE,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_content_course ON ai_content_recommendations (course_id);

-- =============================================================================
--  TABLE 19: ai_generated_questions
--  Questions produced by the GPT question generator (AI Insights → Generate tab).
-- =============================================================================
CREATE TABLE IF NOT EXISTS ai_generated_questions (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses    (id) ON DELETE CASCADE,
    activity_id     TEXT        REFERENCES activities (id) ON DELETE SET NULL,
    topic           TEXT        NOT NULL,              -- e.g. "Object-Oriented Programming"
    question_text   TEXT        NOT NULL,
    question_type   TEXT        NOT NULL
                                CHECK (question_type IN (
                                    'Essay', 'Multiple Choice', 'True/False',
                                    'Short Answer', 'Matching', 'Numerical'
                                )),
    difficulty      TEXT        NOT NULL DEFAULT 'Medium'
                                CHECK (difficulty IN ('Easy', 'Medium', 'Hard')),
    status          TEXT        NOT NULL DEFAULT 'generated'
                                CHECK (status IN (
                                    'generated', 'added_to_bank', 'dismissed'
                                )),
    generated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_ai_genq_course  ON ai_generated_questions (course_id);
CREATE INDEX IF NOT EXISTS idx_ai_genq_status  ON ai_generated_questions (status);

-- =============================================================================
--  TABLE 20: user_preferences
--  Per-user toggle settings (Profile → Preferences panel).
-- =============================================================================
CREATE TABLE IF NOT EXISTS user_preferences (
    id                  TEXT        PRIMARY KEY,
    user_id             TEXT        NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    preference_key      TEXT        NOT NULL,          -- snake_case key e.g. "email_notifications"
    preference_label    TEXT        NOT NULL,          -- display label
    description         TEXT,
    enabled             BOOLEAN     NOT NULL DEFAULT TRUE,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE (user_id, preference_key)
);

CREATE INDEX IF NOT EXISTS idx_user_prefs_user ON user_preferences (user_id);

-- =============================================================================
--  TABLE 21: activity_performance
--  Horizontal bar chart data — average score % per activity.
--  Used on AI Insights → Performance → Activity Performance chart.
-- =============================================================================
CREATE TABLE IF NOT EXISTS activity_performance (
    id                      TEXT        PRIMARY KEY,
    course_id               TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    activity_name           TEXT        NOT NULL,
    avg_score_percentage    NUMERIC(5,2) NOT NULL      -- 0–100
                                        CHECK (avg_score_percentage >= 0 AND avg_score_percentage <= 100),
    grade_max               NUMERIC(7,2),
    recorded_at             DATE        NOT NULL DEFAULT CURRENT_DATE,
    created_at              TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_activity_perf_course ON activity_performance (course_id);

-- =============================================================================
--  TABLE 22: dashboard_engagement
--  Daily engagement data for the Dashboard Weekly Engagement area chart.
-- =============================================================================
CREATE TABLE IF NOT EXISTS dashboard_engagement (
    id              TEXT        PRIMARY KEY,
    course_id       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    day_label       TEXT        NOT NULL,              -- "Mon", "Tue" … "Sun"
    active_students INTEGER     NOT NULL DEFAULT 0,
    submissions     INTEGER     NOT NULL DEFAULT 0,
    week_of         DATE        NOT NULL,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_dashboard_engagement_course ON dashboard_engagement (course_id, week_of);

-- =============================================================================
-- =============================================================================
--  LEARNER ANALYTICS PIPELINE  (L0 → L1 → L2 → L3 → RE → IE → FL)
-- =============================================================================
-- =============================================================================

-- =============================================================================
--  TABLE 23: learner_profiles  (L0 — Declared Profile)
--
--  Collected at onboarding. Defines which profile archetype the learner
--  identifies with. Profile type drives signal WEIGHTS in the Risk Engine (RE).
--
--  Profile Types:
--    H = Heutagogical / Self-Directed
--        Key signals: optional_resource_access_rate, voluntary_engagement_delta
--    A = Activist / Social Learner
--        Key signals: forum_post_rate, peer_response_rate
--    T = Theorist / Task-Oriented
--        Key signals: quiz_learning_delta, submission_timing
--    C = Conformist / Structured
--        Key signals: content_completion_rate, feedback_uptake_lag_hours
--
--  Score thresholds for each type (H/A/T/C scored 0–20):
--    Mixed profile: if top two scores are within 3 points → is_mixed_profile = TRUE
-- =============================================================================
CREATE TABLE IF NOT EXISTS learner_profiles (
    id                      TEXT        PRIMARY KEY,
    learner_id              TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id               TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,

    -- Profile classification
    primary_profile         TEXT        NOT NULL
                                        CHECK (primary_profile IN ('H', 'A', 'T', 'C')),
    secondary_profile       TEXT        CHECK (secondary_profile IN ('H', 'A', 'T', 'C')),
    is_mixed_profile        BOOLEAN     NOT NULL DEFAULT FALSE,
    mixed_blend_primary     NUMERIC(4,2) DEFAULT 1.00, -- 0.00–1.00 weighting for primary
    mixed_blend_secondary   NUMERIC(4,2) DEFAULT 0.00, -- 0.00–1.00 weighting for secondary

    -- Raw HATC profile scores (0–20 each)
    h_score                 SMALLINT    DEFAULT 0 CHECK (h_score BETWEEN 0 AND 20),
    a_score                 SMALLINT    DEFAULT 0 CHECK (a_score BETWEEN 0 AND 20),
    t_score                 SMALLINT    DEFAULT 0 CHECK (t_score BETWEEN 0 AND 20),
    c_score                 SMALLINT    DEFAULT 0 CHECK (c_score BETWEEN 0 AND 20),

    -- Declared learning preferences (text array of preference tags)
    declared_preferences    TEXT[]      DEFAULT '{}',

    -- LMS feature flags (controls which LMS features are pre-enabled for learner)
    lms_flags               JSONB       DEFAULT '{
        "open_navigation": false,
        "structured_pathway": false,
        "reflection_journals": false,
        "peer_review": false,
        "cohort_grouping": false,
        "self_assessment": false,
        "deadline_reminders": false
    }',

    -- Pulse / emotional check-in consent
    pulse_consent           BOOLEAN     NOT NULL DEFAULT FALSE,
    pulse_consent_at        TIMESTAMPTZ,

    -- Profile drift tracking (updated by FL Feedback Loop)
    drift_flag              BOOLEAN     NOT NULL DEFAULT FALSE,
    drift_weeks_count       INTEGER     NOT NULL DEFAULT 0,     -- consecutive weeks of drift
    drift_flagged_at        TIMESTAMPTZ,

    -- Internal note (from sample JSON _note field)
    profile_note            TEXT,

    created_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_at              TIMESTAMPTZ DEFAULT NOW(),

    UNIQUE (learner_id, course_id)
);

CREATE INDEX IF NOT EXISTS idx_lp_learner          ON learner_profiles (learner_id);
CREATE INDEX IF NOT EXISTS idx_lp_course           ON learner_profiles (course_id);
CREATE INDEX IF NOT EXISTS idx_lp_primary_profile  ON learner_profiles (primary_profile);
CREATE INDEX IF NOT EXISTS idx_lp_drift_flag       ON learner_profiles (drift_flag) WHERE drift_flag = TRUE;

-- =============================================================================
--  TABLE 24: behavioral_signals  (L1)
--
--  Weekly behavioral data extracted from LMS activity logs.
--  Computed every Monday from moodle_activity_log / xAPI events.
--
--  Signal definitions:
--    login_frequency           — sessions per week
--    time_on_task_hours        — total active time (hours)
--    content_completion_rate   — fraction of required content accessed (0–1)
--    quiz_attempt_count        — number of quiz attempts made
--    quiz_available_count      — number of quiz attempts available
--    submission_timing         — early | on_time | late_1_2 | late_3_5 | missing
--    forum_post_count          — posts made
--    forum_posts_required      — posts required by course design
--    navigation_pattern        — linear | nonlinear
--
--  normalised_values (JSONB): RE-ready 0–1 values for each signal
--  colour_flags      (JSONB): green | amber | orange | red per signal
--  raw_data          (JSONB): session log, resource counts, LMS source metadata
-- =============================================================================
CREATE TABLE IF NOT EXISTS behavioral_signals (
    id                      TEXT        PRIMARY KEY,
    learner_id              TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id               TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    week_number             SMALLINT    NOT NULL CHECK (week_number >= 1),

    -- Raw behavioral metrics
    login_frequency         SMALLINT    DEFAULT 0,
    time_on_task_hours      NUMERIC(5,2) DEFAULT 0,
    content_completion_rate NUMERIC(5,4) DEFAULT 0     -- 0.0000 – 1.0000
                                         CHECK (content_completion_rate BETWEEN 0 AND 1),
    quiz_attempt_count      SMALLINT    DEFAULT 0,
    quiz_available_count    SMALLINT    DEFAULT 0,
    submission_timing       TEXT        DEFAULT 'on_time'
                                        CHECK (submission_timing IN (
                                            'early', 'on_time', 'late_1_2',
                                            'late_3_5', 'missing'
                                        )),
    forum_post_count        SMALLINT    DEFAULT 0,
    forum_posts_required    SMALLINT    DEFAULT 0,
    navigation_pattern      TEXT        DEFAULT 'linear'
                                        CHECK (navigation_pattern IN ('linear', 'nonlinear')),

    -- RE input data (computed from raw)
    normalised_values       JSONB       DEFAULT '{}',
    colour_flags            JSONB       DEFAULT '{}',
    raw_data                JSONB       DEFAULT '{}',

    computed_at             TIMESTAMPTZ,
    created_at              TIMESTAMPTZ DEFAULT NOW(),

    UNIQUE (learner_id, course_id, week_number)
);

CREATE INDEX IF NOT EXISTS idx_bs_learner ON behavioral_signals (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_bs_week    ON behavioral_signals (course_id, week_number);

-- =============================================================================
--  TABLE 25: cognitive_signals  (L2)
--
--  Computed from xAPI LRS data — measures how the learner processes content.
--
--  Signal definitions:
--    content_revisit_rate          — avg revisits per accessed resource
--    revisit_flag                  — TRUE if any resource accessed ≥ 3 times
--    quiz_first_attempt_score      — score on attempt 1 (0–100)
--    quiz_final_attempt_score      — score on final attempt (0–100)
--    quiz_learning_delta           — improvement fraction (final–first)/(100–first)
--    discussion_depth_score        — NLP-computed quality score 0–100 (NULL if no posts)
--    avg_post_word_count           — average words per forum post
--    question_count                — questions asked in forum posts (NLP)
--    assertion_count               — assertions made in forum posts (NLP)
--    peer_response_rate            — fraction of peers responded to
--    optional_resource_access_rate — optional resources accessed / available
--    feedback_uptake_lag_hours     — hours between feedback received and next login
-- =============================================================================
CREATE TABLE IF NOT EXISTS cognitive_signals (
    id                              TEXT        PRIMARY KEY,
    learner_id                      TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id                       TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    week_number                     SMALLINT    NOT NULL CHECK (week_number >= 1),

    -- Content revisit
    content_revisit_rate            NUMERIC(5,2) DEFAULT 0,
    revisit_flag                    BOOLEAN     NOT NULL DEFAULT FALSE,

    -- Quiz learning quality
    quiz_first_attempt_score        NUMERIC(6,2),
    quiz_final_attempt_score        NUMERIC(6,2),
    quiz_learning_delta             NUMERIC(6,4),      -- 0.0000 – 1.0000

    -- Discussion / forum depth
    discussion_depth_score          NUMERIC(6,2),      -- NULL if no posts this week
    avg_post_word_count             INTEGER     DEFAULT 0,
    question_count                  INTEGER     DEFAULT 0,
    assertion_count                 INTEGER     DEFAULT 0,
    peer_response_rate              NUMERIC(5,4) DEFAULT 0,

    -- Self-directed engagement
    optional_resource_access_rate   NUMERIC(5,4) DEFAULT 0,

    -- Feedback responsiveness
    feedback_uptake_lag_hours       INTEGER,           -- NULL if no feedback received

    -- RE input data (computed from raw)
    normalised_values               JSONB       DEFAULT '{}',
    colour_flags                    JSONB       DEFAULT '{}',
    raw_data                        JSONB       DEFAULT '{}',

    computed_at                     TIMESTAMPTZ,
    created_at                      TIMESTAMPTZ DEFAULT NOW(),

    UNIQUE (learner_id, course_id, week_number)
);

CREATE INDEX IF NOT EXISTS idx_cs_learner      ON cognitive_signals (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_cs_week         ON cognitive_signals (course_id, week_number);
CREATE INDEX IF NOT EXISTS idx_cs_revisit_flag ON cognitive_signals (revisit_flag) WHERE revisit_flag = TRUE;

-- =============================================================================
--  TABLE 26: emotional_signals  (L3)
--
--  Self-reported pulse check-ins + computed emotional/motivational indicators.
--
--  Signal definitions:
--    pulse_confidence              — self-reported confidence (1–5)
--    pulse_energy                  — self-reported energy (1–5)
--    pulse_composite               — weighted composite (avg of confidence + energy)
--    mood_drift_score              — 4-week rolling weighted avg of pulse_composite
--                                   NULL until 2+ data points exist
--    mood_drift_flag               — TRUE if drift score dropped >20% below baseline
--    help_seeking_rate             — (messages + forum_questions) / cohort_avg_rate
--    voluntary_engagement_rate     — optional activities accessed / available
--    voluntary_engagement_delta    — change from previous week (positive = improvement)
--    badge_earned_this_week        — TRUE if any badge awarded this week
--    badge_response_delta          — % change in login/access in 48hrs after badge
-- =============================================================================
CREATE TABLE IF NOT EXISTS emotional_signals (
    id                          TEXT        PRIMARY KEY,
    learner_id                  TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id                   TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    week_number                 SMALLINT    NOT NULL CHECK (week_number >= 1),

    -- Pulse check-in
    pulse_confidence            SMALLINT    CHECK (pulse_confidence BETWEEN 1 AND 5),
    pulse_energy                SMALLINT    CHECK (pulse_energy BETWEEN 1 AND 5),
    pulse_composite             NUMERIC(4,2),          -- avg of confidence + energy (1.0–5.0)
    pulse_submitted             BOOLEAN     NOT NULL DEFAULT FALSE,
    pulse_submitted_at          TIMESTAMPTZ,

    -- Mood drift (rolling average, computed from pulse_composite history)
    mood_drift_score            NUMERIC(4,2),          -- NULL until ≥2 pulse points
    mood_drift_flag             BOOLEAN     NOT NULL DEFAULT FALSE,

    -- Help-seeking behaviour
    help_seeking_rate           NUMERIC(5,4) DEFAULT 0,
    messages_to_facilitator     INTEGER     DEFAULT 0,
    forum_questions_asked       INTEGER     DEFAULT 0,
    feedback_response_lag_hours INTEGER,

    -- Voluntary engagement
    voluntary_engagement_rate   NUMERIC(5,4) DEFAULT 0,
    voluntary_engagement_delta  NUMERIC(7,4),          -- NULL if no prior week baseline

    -- Badge / gamification response
    badge_earned_this_week      BOOLEAN     NOT NULL DEFAULT FALSE,
    badge_response_delta        NUMERIC(6,4),          -- % change in access after badge

    -- RE input data
    colour_flags                JSONB       DEFAULT '{}',
    raw_data                    JSONB       DEFAULT '{}',

    computed_at                 TIMESTAMPTZ,
    created_at                  TIMESTAMPTZ DEFAULT NOW(),

    UNIQUE (learner_id, course_id, week_number)
);

CREATE INDEX IF NOT EXISTS idx_es_learner     ON emotional_signals (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_es_week        ON emotional_signals (course_id, week_number);
CREATE INDEX IF NOT EXISTS idx_es_drift_flag  ON emotional_signals (mood_drift_flag) WHERE mood_drift_flag = TRUE;
CREATE INDEX IF NOT EXISTS idx_es_pulse_low   ON emotional_signals (pulse_composite) WHERE pulse_composite < 2.0;

-- =============================================================================
--  TABLE 27: risk_scores  (RE — Risk Scoring Engine)
--
--  Computed every Monday per learner per course.
--  Aggregates L1 + L2 + L3 weighted contributions into a final risk score (0–100).
--  The tier value drives the Intervention Engine (IE).
--
--  Tier thresholds:
--    0 = GREEN  (0–25)   — passive monitoring
--    1 = AMBER  (25–50)  — auto-nudge via IE template
--    2 = ORANGE (50–75)  — facilitator outreach within 48hrs
--    3 = RED    (75–100) — immediate pastoral escalation
--
--  anomaly_flag = TRUE when score_delta > 20 in a single week
--
--  signal_breakdown (JSONB) structure per signal key:
--    { "raw": <value>, "normalised": 0–1, "weight": 0–1, "contribution": pts, "colour": flag }
--
--  Profile-specific weights (example for H-profile):
--    optional_resource_access_rate  0.20
--    quiz_learning_delta            0.15
--    mood_drift_score               0.20
--    voluntary_engagement_delta     0.15
--    time_on_task_hours             0.10
--    login_frequency                0.10
--    feedback_uptake_lag_hours      0.10
--    forum_post_rate                0.00  (not scored for H)
-- =============================================================================
CREATE TABLE IF NOT EXISTS risk_scores (
    id                      TEXT        PRIMARY KEY,
    learner_id              TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id               TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    week_number             SMALLINT    NOT NULL CHECK (week_number >= 1),
    profile_type            TEXT        NOT NULL
                                        CHECK (profile_type IN ('H', 'A', 'T', 'C', 'mixed')),

    -- Layer contributions (0–100 each; their weighted sum = final_score)
    l1_contribution         NUMERIC(6,3) DEFAULT 0,   -- behavioural layer points
    l2_contribution         NUMERIC(6,3) DEFAULT 0,   -- cognitive layer points
    l3_contribution         NUMERIC(6,3) DEFAULT 0,   -- emotional layer points

    -- Scores
    primary_score           NUMERIC(6,3),              -- score from primary profile weights
    secondary_score         NUMERIC(6,3),              -- score from secondary profile (mixed only)
    final_score             NUMERIC(6,3) NOT NULL      -- blended/primary, 0–100
                                         CHECK (final_score >= 0 AND final_score <= 100),

    -- Trend
    previous_week_score     NUMERIC(6,3),              -- NULL in calibration weeks
    score_delta             NUMERIC(7,3),              -- final_score – previous_week_score

    -- Risk classification
    tier                    SMALLINT    NOT NULL DEFAULT 0
                                        CHECK (tier BETWEEN 0 AND 3),
    anomaly_flag            BOOLEAN     NOT NULL DEFAULT FALSE,

    -- Full signal-level breakdown (JSONB)
    signal_breakdown        JSONB       DEFAULT '{}',

    -- Auto-generated facilitator narrative from RE
    facilitator_notes_prompt TEXT,

    computed_at             TIMESTAMPTZ,
    created_at              TIMESTAMPTZ DEFAULT NOW(),

    UNIQUE (learner_id, course_id, week_number)
);

CREATE INDEX IF NOT EXISTS idx_rs_learner      ON risk_scores (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_rs_week         ON risk_scores (course_id, week_number);
CREATE INDEX IF NOT EXISTS idx_rs_tier         ON risk_scores (tier);
CREATE INDEX IF NOT EXISTS idx_rs_anomaly      ON risk_scores (anomaly_flag) WHERE anomaly_flag = TRUE;
CREATE INDEX IF NOT EXISTS idx_rs_high_risk    ON risk_scores (final_score) WHERE final_score >= 50;

-- =============================================================================
--  TABLE 28: interventions  (IE — Intervention Engine)
--
--  Records every automated and facilitator-initiated intervention.
--  Triggered by risk_scores.tier crossing a threshold.
--
--  Tier → channel mapping (defaults, overridable by facilitator):
--    T1 AMBER  → lms_message (automated template)
--    T2 ORANGE → lms_message + email (facilitator-personalised)
--    T3 RED    → video_call + pastoral_referral (human-led)
--
--  Template naming convention: {PROFILE}_{TIER}_{FOCUS}
--    e.g. H_T1_nudge | C_T2_pedagogical | A_T3_pastoral
--
--  cooldown_expires_at: next intervention for same learner blocked until this time
--  score_at_t7:  RE score re-checked 7 days after intervention (FL)
--  score_at_t14: RE score re-checked 14 days after intervention (FL)
--  outcome:      populated by feedback_evaluations after evaluation period
-- =============================================================================
CREATE TABLE IF NOT EXISTS interventions (
    id                  TEXT        PRIMARY KEY,
    learner_id          TEXT        NOT NULL REFERENCES users   (id) ON DELETE CASCADE,
    course_id           TEXT        NOT NULL REFERENCES courses (id) ON DELETE CASCADE,
    facilitator_id      TEXT        REFERENCES users (id) ON DELETE SET NULL,
    week_number         SMALLINT    NOT NULL,

    -- Trigger context
    tier                SMALLINT    NOT NULL CHECK (tier BETWEEN 1 AND 3),
    trigger_score       NUMERIC(6,3) NOT NULL,
    profile_type        TEXT        NOT NULL
                                    CHECK (profile_type IN ('H', 'A', 'T', 'C', 'mixed')),

    -- Delivery
    channel             TEXT        NOT NULL
                                    CHECK (channel IN (
                                        'lms_message', 'email',
                                        'video_call', 'pastoral_referral'
                                    )),
    template_id         TEXT        NOT NULL,          -- e.g. "H_T1_nudge"
    message_body        TEXT        NOT NULL,

    -- Timing
    sent_at             TIMESTAMPTZ,
    cooldown_expires_at TIMESTAMPTZ,

    -- FL outcome tracking (populated by feedback_evaluations)
    score_at_t7         NUMERIC(6,3),                  -- RE score 7 days post-intervention
    score_at_t14        NUMERIC(6,3),                  -- RE score 14 days post-intervention
    outcome             TEXT        CHECK (outcome IN (
                                        'no_change', 'partial_recovery',
                                        'recovered', 'escalated'
                                    )),                -- NULL until evaluated

    notes               TEXT,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_iv_learner  ON interventions (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_iv_tier     ON interventions (tier);
CREATE INDEX IF NOT EXISTS idx_iv_week     ON interventions (course_id, week_number);
CREATE INDEX IF NOT EXISTS idx_iv_outcome  ON interventions (outcome);
CREATE INDEX IF NOT EXISTS idx_iv_pending  ON interventions (outcome) WHERE outcome IS NULL;

-- =============================================================================
--  TABLE 29: feedback_evaluations  (FL — Feedback Loop)
--
--  Evaluates whether interventions achieved recovery (T+7, T+14 check-ins).
--  Feeds back into the RE model to refine tier thresholds per profile type.
--
--  recovery_threshold_met:
--    TRUE  if final_score dropped ≥10pts from trigger_score within 14 days
--
--  re_threshold_adjustment (JSONB):
--    If outcome = 'worsened', system may recommend reducing trigger thresholds.
--    e.g. {"profile":"C","recommendation":"reduce T1 from 40 to 35","rationale":"..."}
--
--  This table drives the model learning loop:
--    outcome 'worsened' → lower tier trigger threshold for that profile type
--    outcome 'recovered' → current threshold appropriate
--    outcome 'partial_recovery' → monitor, no change
--    outcome 'escalated' → re-evaluate intervention channel for profile
-- =============================================================================
CREATE TABLE IF NOT EXISTS feedback_evaluations (
    id                          TEXT        PRIMARY KEY,
    intervention_id             TEXT        NOT NULL REFERENCES interventions (id) ON DELETE CASCADE,
    learner_id                  TEXT        NOT NULL REFERENCES users         (id) ON DELETE CASCADE,
    course_id                   TEXT        NOT NULL REFERENCES courses       (id) ON DELETE CASCADE,
    evaluated_at_week           SMALLINT    NOT NULL,

    -- Score trajectory
    score_before                NUMERIC(6,3) NOT NULL,
    score_at_t7                 NUMERIC(6,3),
    score_at_t14                NUMERIC(6,3),
    score_delta_t7              NUMERIC(7,3),          -- score_at_t7  – score_before (negative = improvement)
    score_delta_t14             NUMERIC(7,3),          -- score_at_t14 – score_before (negative = improvement)

    -- Outcome
    recovery_threshold_met      BOOLEAN     NOT NULL DEFAULT FALSE,
    outcome_label               TEXT        NOT NULL
                                            CHECK (outcome_label IN (
                                                'recovered', 'partial_recovery',
                                                'no_change', 'worsened', 'escalated'
                                            )),

    -- RE calibration recommendation
    re_threshold_adjustment     JSONB,                 -- NULL if no change required

    -- Human-readable model notes
    model_notes                 TEXT,

    created_at                  TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_fe_intervention ON feedback_evaluations (intervention_id);
CREATE INDEX IF NOT EXISTS idx_fe_learner      ON feedback_evaluations (learner_id);
CREATE INDEX IF NOT EXISTS idx_fe_outcome      ON feedback_evaluations (outcome_label);
CREATE INDEX IF NOT EXISTS idx_fe_worsened     ON feedback_evaluations (outcome_label)
    WHERE outcome_label IN ('worsened', 'escalated');

-- =============================================================================
--  TABLE 30: profile_drift_logs  (FL — Feedback Loop)
--
--  Records when a learner's actual behaviour diverges from their declared
--  L0 profile for 2+ consecutive weeks (profile drift detection).
--
--  drift_severity:
--    mild     — partial degradation, still recognisably on-profile
--    moderate — significant mismatch but some on-profile signals remain
--    severe   — complete inversion or withdrawal; antithetical to profile
--
--  When drift is detected:
--    1. learner_profiles.drift_flag is set to TRUE
--    2. learner_profiles.drift_weeks_count is incremented
--    3. RE applies "disengaged" signal weights until drift resolves
--    4. facilitator_alerted = TRUE triggers notification
--    5. Profile re-declaration offer sent to learner (configurable at week N)
--
--  resolution values:
--    partial_recovery — signals improved, drift flag removed
--    re_declared      — learner updated their L0 profile
--    NULL             — unresolved / ongoing
-- =============================================================================
CREATE TABLE IF NOT EXISTS profile_drift_logs (
    id                  TEXT        PRIMARY KEY,
    learner_id          TEXT        NOT NULL REFERENCES users          (id) ON DELETE CASCADE,
    course_id           TEXT        NOT NULL REFERENCES courses        (id) ON DELETE CASCADE,
    detected_at_week    SMALLINT    NOT NULL,

    -- What was declared vs what was observed
    declared_profile    TEXT        NOT NULL CHECK (declared_profile IN ('H', 'A', 'T', 'C')),
    observed_pattern    TEXT        NOT NULL,          -- narrative description of actual behaviour
    drift_direction     TEXT        NOT NULL,          -- e.g. "A → isolated (inverse of declared)"

    -- Severity classification
    drift_severity      TEXT        NOT NULL DEFAULT 'mild'
                                    CHECK (drift_severity IN ('mild', 'moderate', 'severe')),

    -- Timestamps and flags
    drift_confirmed_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    facilitator_alerted BOOLEAN     NOT NULL DEFAULT FALSE,

    -- Resolution tracking
    resolution          TEXT        CHECK (resolution IN (
                                        'partial_recovery', 're_declared', NULL
                                    )),
    resolved_at         TIMESTAMPTZ,

    -- System notes
    notes               TEXT,

    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_pdl_learner   ON profile_drift_logs (learner_id, course_id);
CREATE INDEX IF NOT EXISTS idx_pdl_severity  ON profile_drift_logs (drift_severity);
CREATE INDEX IF NOT EXISTS idx_pdl_unresolved ON profile_drift_logs (resolution)
    WHERE resolution IS NULL;

