('qa1',  'qq1','x = 10',             1.0, 'Correct! This is the standard way to assign a variable in Python.', 0),
('qa2',  'qq1','int x = 10;',        0.0, 'Incorrect. That is Java/C# syntax, not Python.',                    1),
('qa3',  'qq1','var x = 10',         0.0, 'Incorrect. That is JavaScript syntax.',                             2),
('qa4',  'qq1','declare x = 10',     0.0, 'Incorrect. Python does not use a ''declare'' keyword.',             3),
('qa5',  'qq5','print()',             1.0, NULL, 0),
('qa6',  'qq5','len()',               1.0, NULL, 1),
('qa7',  'qq5','range()',             1.0, NULL, 2),
('qa8',  'qq7','Linear Regression',  1.0, 'Correct! Linear Regression is a supervised learning algorithm.',   0),
('qa9',  'qq7','K-Means Clustering', 0.0, 'Incorrect. K-Means is an unsupervised algorithm.',                  1),
('qa10', 'qq7','DBSCAN',             0.0, 'Incorrect. DBSCAN is unsupervised.',                                2),
('qa11', 'qq7','PCA',                0.0, 'Incorrect. PCA is a dimensionality reduction technique.',           3),
('qa12', 'qq8','Sigmoid',            1.0, 'Correct! Sigmoid outputs 0–1, ideal for binary classification.',   0),
('qa13', 'qq8','ReLU',               0.0, 'Incorrect. ReLU is typically used in hidden layers.',               1),
('qa14', 'qq8','Softmax',            0.0, 'Incorrect. Softmax is used for multi-class classification.',        2),
('qa15', 'qq8','Tanh',               0.0, 'Incorrect. Tanh is used in hidden layers or RNNs.',                 3)
ON CONFLICT (id) DO NOTHING;

